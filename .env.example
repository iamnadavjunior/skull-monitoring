# ── Database ──────────────────────────────────────────
DB_ROOT_PASSWORD=rootsecret
DB_NAME=openschool
DB_USER=openschool
DB_PASS=openschool_secret

# ── Application ──────────────────────────────────────
APP_URL=http://localhost
APP_PORT=80

# Generate a strong secret:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRY=86400

# ── Ports (host mapping) ─────────────────────────────
DB_PORT_EXPOSE=3306
